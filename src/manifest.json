{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.0.9",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "assets/extension-icons/icon-16.png",
    "32": "assets/extension-icons/icon-32.png",
    "48": "assets/extension-icons/icon-48.png",
    "128": "assets/extension-icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "__MSG_extensionName__",
    "default_icon": {
      "16": "assets/extension-icons/icon-16.png",
      "32": "assets/extension-icons/icon-32.png",
      "48": "assets/extension-icons/icon-48.png",
      "128": "assets/extension-icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://matrix.itasoftware.com/*"],
      "js": ["content/itaMatrixContent.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.skyscanner.ae/transport/*",
        "https://www.skyscanner.at/transport/*",
        "https://skyscanner.com/transport/*",
        "https://www.skyscanner.com/transport/*",
        "https://www.skyscanner.co.kr/transport/*",
        "https://www.skyscanner.net/transport/*",
        "https://www.skyscanner.ca/transport/*",
        "https://www.skyscanner.com.au/transport/*",
        "https://www.skyscanner.cl/transport/*",
        "https://www.skyscanner.co.il/transport/*",
        "https://www.skyscanner.co.uk/transport/*",
        "https://www.skyscanner.co.nz/transport/*",
        "https://www.skyscanner.com.sg/transport/*",
        "https://www.skyscanner.com.ar/transport/*",
        "https://www.skyscanner.com.co/transport/*",
        "https://www.skyscanner.com.eg/transport/*",
        "https://www.skyscanner.com.hk/transport/*",
        "https://www.skyscanner.com.pe/transport/*",
        "https://www.skyscanner.com.tw/transport/*",
        "https://www.skyscanner.com.ua/transport/*",
        "https://www.skyscanner.jp/transport/*",
        "https://www.skyscanner.com.my/transport/*",
        "https://www.skyscanner.es/transport/*",
        "https://www.skyscanner.com.vn/transport/*",
        "https://www.skyscanner.co.za/transport/*",
        "https://www.skyscanner.co.in/transport/*",
        "https://www.skyscanner.com.ph/transport/*",
        "https://www.skyscanner.co.id/transport/*",
        "https://www.skyscanner.co.th/transport/*",
        "https://www.skyscanner.be/transport/*",
        "https://www.skyscanner.com.br/transport/*",
        "https://www.skyscanner.ch/transport/*",
        "https://cn.skyscanner.com/transport/*",
        "https://www.skyscanner.de/transport/*",
        "https://www.skyscanner.dk/transport/*",
        "https://www.skyscanner.fi/transport/*",
        "https://www.skyscanner.fr/transport/*",
        "https://gr.skyscanner.com/transport/*",
        "https://www.skyscanner.ie/transport/*",
        "https://www.skyscanner.it/transport/*",
        "https://www.skyscanner.com.mx/transport/*",
        "https://www.skyscanner.nl/transport/*",
        "https://www.skyscanner.no/transport/*",
        "https://www.skyscanner.pl/transport/*",
        "https://www.skyscanner.pt/transport/*",
        "https://ro.skyscanner.com/transport/*",
        "https://www.skyscanner.ru/transport/*",
        "https://www.skyscanner.se/transport/*",
        "https://www.skyscanner.com.tr/transport/*"
      ],
      "js": ["content/skyscannerSearchPageHook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.google.com/travel/flights*", "https://google.com/travel/flights*"],
      "js": ["content/googleFlightsContent.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://matrix.itasoftware.com/*",
    "https://www.google.com/travel/flights*",
    "https://google.com/travel/flights*",
    "https://cdn.jsdelivr.net/*",
    "https://api.fxratesapi.com/*"
  ],
  "permissions": ["storage", "clipboardWrite"],
  "options_page": "options/index.html"
}
