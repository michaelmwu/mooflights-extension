{
  "name": "flights-extension",
  "version": "0.1.0",
  "description": "Mu Travel browser extension for ITA Matrix flight workflows.",
  "license": "AGPL-3.0-only",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/build.mjs --dev",
    "clean": "rimraf dist",
    "check": "biome check .",
    "dev": "node scripts/build.mjs --watch",
    "format": "biome format --write .",
    "import:airport-coordinates": "node scripts/import-airports.mjs",
    "import:airports": "node scripts/import-airports.mjs",
    "lint": "biome lint .",
    "package": "bun run build && node scripts/package-extension.mjs",
    "release:verify": "node scripts/verify-release-version.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/chrome": "^0.1.34",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.27.2",
    "jsdom": "^27.3.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
